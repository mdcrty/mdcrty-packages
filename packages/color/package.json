{
  "name": "@mdcrty/color",
  "version": "0.2.1",
  "description": "A zero-dependency React colour picker and converter component.",
  "keywords": [
    "react",
    "color",
    "colour",
    "picker",
    "converter"
  ],
  "license": "MIT",
  "type": "module",
